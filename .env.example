# MySQL Source Database
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# NEON (PostgreSQL) Target Database
# Format: postgresql+psycopg2://user:password@host/dbname?sslmode=require
NEON_DATABASE_URL=

# Application Settings
ENVIRONMENT=production
LOG_LEVEL=INFO
SYNC_CONFIG_PATH=/app/config.yaml
BATCH_SIZE=1000
